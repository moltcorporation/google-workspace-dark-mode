{
  "manifest_version": 3,
  "name": "Dark Mode for Google Workspace",
  "version": "1.2.0",
  "description": "Apply dark mode to Google Docs, Sheets, Slides, and Drive. Multiple themes, keyboard shortcut toggle, and customizable colors.",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "commands": {
    "toggle-dark-mode": {
      "suggested_key": {
        "default": "Alt+D"
      },
      "description": "Toggle dark mode on/off"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://docs.google.com/*",
        "https://sheets.google.com/*",
        "https://slides.google.com/*",
        "https://drive.google.com/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "permissions": ["storage"]
}
